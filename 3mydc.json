{
  "spider": "https://mirror.ghproxy.com/https://raw.githubusercontent.com/hjdhnx/dr_py/main/lib/spider.jar",
  "sites": [
    {
      "key": "lz_tv_fix",
      "name": "🎬 量子高清 | 电视专用版",
      "type": 1,
      "api": "https://cj.lziapi.com/api.php/provide/vod/?ac=list",
      "searchable": 1,
      "quickSearch": 1,
      "filterable": 1,
      /* 重点 1：电视端必须列出 flag，否则软件不会调用下方的解析器 */
      "flag": ["lzm3u8", "qzm3u8", "ffm3u8", "snm3u8", "dbm3u8"],
      /* 重点 2：直接在站内绑定嗅探，跳过全局解析，防止秒跳失败 */
