      "ua": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36",
      "class": [
        {"type_id": 1, "type_name": "电影"},
        {"type_id": 2, "type_name": "连续剧"},
        {"type_id": 3, "type_name": "综艺"},
        {"type_id": 4, "type_name": "动漫"}
      ]
    }
  ],
  "parses": [
    /* 重点 4：电视端首选 Web 聚合解析 */
    { "name": "💡 聚合解析", "type": 3, "url": "Web" },
    { "name": "🚀 极速解析", "type": 0, "url": "https://jx.jsonplayer.com/player/?url=" }
  ],
  "rules": [
    { 
      "name": "量子去广告", 
      "hosts": ["vip.lz", "hd.lz"], 
      "regex": ["#EXT-X-DISCONTINUITY\\r*\\n*#EXTINF:7\\.166667,[\\s\\S]*?#EXT-X-DISCONTINUITY"] 
    }
  ]
